=== sample EN structure with examples ===
[
  {
    "id": 147,
    "structure_label": "Have to for external obligation",
    "pattern": "[Subject] + have to/has to + [base verb]",
    "core_meaning": "Obligation from rules or situation.",
    "example_index": 3,
    "text_en": "We don't have to stay until the end.",
    "text_target": null
  },
  {
    "id": 116,
    "structure_label": "Future: will vs going to (predictions)",
    "pattern": "I think + will; Look at... + going to.",
    "core_meaning": "Prediction based on opinion (will) vs evidence (going to).",
    "example_index": 2,
    "text_en": "She's going to have a baby. (seen her belly)",
    "text_target": null
  },
  {
    "id": 261,
    "structure_label": "Might for possibility",
    "pattern": "[Subject] + might + [base verb]",
    "core_meaning": "Weak possibility, maybe.",
    "example_index": 1,
    "text_en": "He might be in his office.",
    "text_target": null
  },
  {
    "id": 323,
    "structure_label": "What about + noun/verb-ing? (suggestion)",
    "pattern": "What about + [noun / verb-ing]?",
    "core_meaning": "Proposing an alternative or including something.",
    "example_index": 3,
    "text_en": "We need a present. What about a book?",
    "text_target": null
  },
  {
    "id": 123,
    "structure_label": "Third conditional (If + had + past participle, would have + past participle)",
    "pattern": "If + [Past Perfect], [would have + past participle]",
    "core_meaning": "Imaginary past situation, regret.",
    "example_index": 3,
    "text_en": "If I had known, I would have told you.",
    "text_target": null
  },
  {
    "id": 184,
    "structure_label": "To be honest, ...",
    "pattern": "To be honest, + [clause]",
    "core_meaning": "Introducing frank opinion.",
    "example_index": 3,
    "text_en": "To be honest, I'm exhausted.",
    "text_target": null
  },
  {
    "id": 278,
    "structure_label": "it must / might / can't be (deduction)",
    "pattern": "It + must/might/can't + be + [noun/adjective/verb-ing]",
    "core_meaning": "Logical deduction about present.",
    "example_index": 2,
    "text_en": "It can't be that hard.",
    "text_target": null
  },
  {
    "id": 282,
    "structure_label": "Is it okay if I...? / Can I...? variations",
    "pattern": "Is it okay/ alright if I + [present simple]?",
    "core_meaning": "Casual permission.",
    "example_index": 2,
    "text_en": "Can I have a glass of water?",
    "text_target": null
  },
  {
    "id": 10,
    "structure_label": "Who is + [person]?",
    "pattern": "Who is + that/he/she/this?",
    "core_meaning": "Asking about a person’s identity.",
    "example_index": 1,
    "text_en": "Who’s that man?",
    "text_target": null
  },
  {
    "id": 222,
    "structure_label": "How do you say ... in English?",
    "pattern": "How do you say + [word/expression] + in English?",
    "core_meaning": "Asking for translation/expression.",
    "example_index": 1,
    "text_en": "How do you say \"biblioteca\" in English?",
    "text_target": null
  },
  {
    "id": 24,
    "structure_label": "I want to + [verb]",
    "pattern": "I want to + base verb | She wants to + base verb",
    "core_meaning": "Expressing a desire to do something.",
    "example_index": 2,
    "text_en": "Do you want to watch TV?",
    "text_target": null
  },
  {
    "id": 7,
    "structure_label": "It is + [colour / size / descriptive adjective]",
    "pattern": "It is + colour/size adjective",
    "core_meaning": "Describing the most basic properties of an object.",
    "example_index": 2,
    "text_en": "It’s very small.",
    "text_target": null
  }
]

